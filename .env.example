# ── Duty Bot configuration / Конфигурация Duty Bot ──────────────────────
# Copy this file to .env and fill in the values.
# Скопируйте этот файл в .env и заполните значения.
# .env is gitignored / .env в git не попадает (см. .gitignore).

# Bot token — get one from @BotFather in Telegram
# Токен бота — получить у @BotFather в Telegram
BOT_TOKEN=

# Admin's Telegram user id (a number). Ask @userinfobot for yours.
# Telegram user_id администратора (число). Узнать свой — у @userinfobot.
ADMIN_ID=

# Path to the source Excel schedule (format described in README).
# Путь к исходному Excel-файлу с графиком (формат описан в README).
# The demo file lets you start right away / Демо-файл позволяет стартовать сразу:
EXCEL_FILE=examples/schedule_demo.xlsx
